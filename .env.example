# multiplyz — variables d'environnement (exemple)
#
# Copier ce fichier vers .env (JAMAIS commité) et renseigner les valeurs.
# En production (Forge), les valeurs sont injectées via Forge env / GitHub Secrets
# (cf. WORKFLOW.md §15). La config est validée au boot (fail-fast) — voir
# src/instrumentation.ts.

# Chemin du fichier SQLite local (défaut : ./data/multiplyz.sqlite)
DATABASE_PATH=./data/multiplyz.sqlite

# ⚙️ Réglage SQLite — busy_timeout en millisecondes (défaut : 5000)
SQLITE_BUSY_TIMEOUT_MS=5000

# ⚙️ Modèle d'image pour la génération de mondes (défaut : gemini-2.5-flash-image / Nano Banana)
IMAGE_MODEL=gemini-2.5-flash-image

# Clé API du modèle d'image (Gemini) — REQUISE en production.
# Si absente au démarrage en production, le serveur refuse de booter (fail-fast).
GEMINI_API_KEY=

# --- Auth-lite (AUTH.md) — tous OPTIONNELS : défauts sûrs si absents ---
# Durées de session en ms (défauts : enfant 30 j = 2592000000, parent 15 min = 900000)
AUTH_CHILD_SESSION_MS=2592000000
AUTH_PARENT_SESSION_MS=900000
# ⚙️ Coût argon2id (défauts OWASP : 19456 KiB, t=2, p=1)
AUTH_ARGON2_MEMORY_KIB=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1
# ⚙️ Rate-limit tentatives PIN (posés ici, consommés en #2.4)
AUTH_MAX_PIN_ATTEMPTS=5
AUTH_IP_MAX_PIN_ATTEMPTS=15
AUTH_BACKOFF_BASE_MS=1000
AUTH_BACKOFF_FACTOR=2
AUTH_BACKOFF_MAX_MS=300000

# --- Pipeline mondes IA (WORLDGEN.md / ADR 0008) — tous OPTIONNELS : défauts sûrs ---
# ⚙️ Plafond budgétaire mensuel de génération, en euros (défaut : 20 — garde-fou coût WORLDGEN §2)
WORLDGEN_MONTHLY_BUDGET_EUR=20
# ⚙️ Mondes d'avance maintenus (buffer, défaut : 2 — WORLDGEN §3)
WORLDGEN_BUFFER_AHEAD=2
# ⚙️ Retry réseau transitoire du client image (ADR 0008 : 429/500/503 → backoff)
# maxRetries = nombre de ré-essais (défaut : 3 ; 0 = désactivé) ; backoff de base en ms (défaut : 500)
WORLDGEN_MAX_RETRIES=3
WORLDGEN_RETRY_BACKOFF_MS=500
# ⚙️ Prompts de base verrouillés (charte ART §5) — défauts = charte. À NE surcharger qu'au playtest.
# WORLDGEN_PROMPT_STYLE=
# WORLDGEN_PROMPT_NEGATIVE=
# WORLDGEN_PROMPT_TEDDY=
# WORLDGEN_PROMPT_CREATURE=
# WORLDGEN_PROMPT_BACKGROUND=

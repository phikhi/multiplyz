# multiplyz — variables d'environnement (exemple)
#
# Copier ce fichier vers .env (JAMAIS commité) et renseigner les valeurs.
# En production (Forge), les valeurs sont injectées via Forge env / GitHub Secrets
# (cf. WORKFLOW.md §15). La config est validée au boot (fail-fast) — voir
# src/instrumentation.ts.

# Chemin du fichier SQLite local (défaut : ./data/multiplyz.sqlite)
DATABASE_PATH=./data/multiplyz.sqlite

# ⚙️ Réglage SQLite — busy_timeout en millisecondes (défaut : 5000)
SQLITE_BUSY_TIMEOUT_MS=5000

# ⚙️ Modèle d'image pour la génération de mondes (défaut : gemini-2.5-flash-image / Nano Banana)
IMAGE_MODEL=gemini-2.5-flash-image

# Clé API du modèle d'image (Gemini) — REQUISE en production.
# Si absente au démarrage en production, le serveur refuse de booter (fail-fast).
GEMINI_API_KEY=

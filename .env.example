# multiplyz — variables d'environnement (exemple)
#
# Copier ce fichier vers .env (JAMAIS commité) et renseigner les valeurs.
# En production (Forge), les valeurs sont injectées via Forge env / GitHub Secrets
# (cf. WORKFLOW.md §15). La config est validée au boot (fail-fast) — voir
# src/instrumentation.ts.

# Chemin du fichier SQLite local (défaut : ./data/multiplyz.sqlite)
DATABASE_PATH=./data/multiplyz.sqlite

# ⚙️ Réglage SQLite — busy_timeout en millisecondes (défaut : 5000)
SQLITE_BUSY_TIMEOUT_MS=5000

# ⚙️ Modèle d'image pour la génération de mondes (défaut : gemini-2.5-flash-image / Nano Banana)
IMAGE_MODEL=gemini-2.5-flash-image

# Clé API du modèle d'image (Gemini) — REQUISE en production.
# Si absente au démarrage en production, le serveur refuse de booter (fail-fast).
GEMINI_API_KEY=

# --- Auth-lite (AUTH.md) — tous OPTIONNELS : défauts sûrs si absents ---
# Durées de session en ms (défauts : enfant 30 j = 2592000000, parent 15 min = 900000)
AUTH_CHILD_SESSION_MS=2592000000
AUTH_PARENT_SESSION_MS=900000
# ⚙️ Coût argon2id (défauts OWASP : 19456 KiB, t=2, p=1)
AUTH_ARGON2_MEMORY_KIB=19456
AUTH_ARGON2_TIME_COST=2
AUTH_ARGON2_PARALLELISM=1
# ⚙️ Rate-limit tentatives PIN (posés ici, consommés en #2.4)
AUTH_MAX_PIN_ATTEMPTS=5
AUTH_IP_MAX_PIN_ATTEMPTS=15
AUTH_BACKOFF_BASE_MS=1000
AUTH_BACKOFF_FACTOR=2
AUTH_BACKOFF_MAX_MS=300000

# --- Pipeline mondes IA (WORLDGEN.md / ADR 0008) — tous OPTIONNELS : défauts sûrs ---
# ⚙️ Plafond budgétaire mensuel de génération, en euros (défaut : 20 — garde-fou coût WORLDGEN §2)
WORLDGEN_MONTHLY_BUDGET_EUR=20
# ⚙️ Mondes d'avance maintenus (buffer, défaut : 2 — WORLDGEN §3)
WORLDGEN_BUFFER_AHEAD=2
# ⚙️ Retry réseau transitoire du client image (ADR 0008 : 429/500/503 → backoff)
# maxRetries = nombre de ré-essais (défaut : 3 ; 0 = désactivé) ; backoff de base en ms (défaut : 500)
WORLDGEN_MAX_RETRIES=3
WORLDGEN_RETRY_BACKOFF_MS=500
# ⚙️ Prompts de base verrouillés (charte ART §5) — défauts = charte. À NE surcharger qu'au playtest.
# WORLDGEN_PROMPT_STYLE=
# WORLDGEN_PROMPT_NEGATIVE=
# WORLDGEN_PROMPT_TEDDY=
# WORLDGEN_PROMPT_CREATURE=
# WORLDGEN_PROMPT_BACKGROUND=
# ⚙️ Outil Stage A (master Teddy + model sheet, WORLDGEN §8, story 6.2) — one-shot, hors runtime enfant.
# Dossiers gitignorés (photos privées + assets dérivés). Défauts : docs/teddy → storage/reference/teddy.
# WORLDGEN_STAGE_A_PHOTOS_DIR=docs/teddy
# WORLDGEN_STAGE_A_OUTPUT_DIR=storage/reference/teddy
# ⚙️ Stratégie de fond (ADR 0008 contrainte 3) : post-cutout (détourage, défaut) | full-card
# WORLDGEN_STAGE_A_BACKGROUND_STRATEGY=post-cutout
# ⚙️ Couleur du matte de génération (fond plein à détourer en post-cutout) — défaut blanc
# WORLDGEN_STAGE_A_MATTE_COLOR=#ffffff
# ⚙️ Modération kid-safe + validation parent (WORLDGEN §6, story 6.5) — tous OPTIONNELS.
# Toggle validation parent : true = un monde QA-validé attend l'approbation parent avant d'être
# actif ; false (défaut) = actif auto après QA (ADR 0008 « aucune sur-censure »).
# Depuis la story 7.3 (ADR 0013), la SOURCE DE VÉRITÉ est le réglage parent persisté
# (`household_settings`, réglable depuis /parent/reglages) ; cette variable n'est plus que le
# DÉFAUT D'AMORÇAGE d'un foyer qui n'a pas encore touché le réglage.
# WORLDGEN_QA_PARENT_VALIDATION=false
# Régénérations après un rejet QA avant de rester sur le fallback (défaut : 3 ; 0 = aucune).
# WORLDGEN_QA_MAX_ATTEMPTS=3
# Seuils ⚙️ des règles kid-safe [0,1] : score effrayant MAX toléré (défaut 0.5), style MIN exigé (0.6).
# WORLDGEN_QA_UNSAFE_MAX_SCORE=0.5
# WORLDGEN_QA_STYLE_MIN_SCORE=0.6

# ⚙️ Contrôles parentaux — temps d'écran (DETAILS §3 (Temps d'écran), story 7.3) — tous OPTIONNELS.
# DÉFAUTS + BORNES de validation des réglages persistés par foyer (`household_settings`). POSÉS +
# VALIDÉS + STOCKÉS en 7.3 ; l'enforcement runtime (nudge de session / verrou dur) = story 7.8 #229.
# Nudge doux (min de session) : défaut 20, plage admissible 5..60.
# PARENT_SCREEN_TIME_NUDGE_DEFAULT_MIN=20
# PARENT_SCREEN_TIME_NUDGE_MIN=5
# PARENT_SCREEN_TIME_NUDGE_MAX=60
# Verrou dur optionnel (min/jour) : défaut 45, plage admissible 10..240.
# PARENT_SCREEN_TIME_HARD_LOCK_DEFAULT_MIN=45
# PARENT_SCREEN_TIME_HARD_LOCK_MIN=10
# PARENT_SCREEN_TIME_HARD_LOCK_MAX=240

# ⚙️ Réglages son — bruitages/musique/volume (DETAILS §3, story 8.3) — tous OPTIONNELS.
# DÉFAUTS d'un foyer neuf persistés par foyer (`household_settings`). POSÉS + VALIDÉS + STOCKÉS
# en 8.3 ; l'enforcement runtime (moteur audio réel) = story 8.4 (inexistante ici).
# SOUND_ENABLED_DEFAULT=true
# MUSIC_ENABLED_DEFAULT=true
# Volume par défaut, pourcentage entier [0,100].
# SOUND_VOLUME_DEFAULT=70
